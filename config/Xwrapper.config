# /etc/X11/Xwrapper.config
# Copy to: /etc/X11/Xwrapper.config
#
# WHY allowed_users=anybody:
# The speedometer service has no console stdin (StandardInput defaults to
# /dev/null in systemd). Xorg's default "console" check verifies that the
# caller's stdin is a VT (char device, major 4). The service fails this check,
# so xinit (called on Ctrl+M) is refused with "Only console users are allowed".
# Setting allowed_users=anybody bypasses that check so the service process can
# start the X server for Minetest.

allowed_users=anybody

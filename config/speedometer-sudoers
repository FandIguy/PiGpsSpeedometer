# /etc/sudoers.d/speedometer
# Copy to: /etc/sudoers.d/speedometer
# Set permissions: sudo chmod 440 /etc/sudoers.d/speedometer
# Validate before copying: sudo visudo -c -f config/speedometer-sudoers
#
# Allows the stealth user to switch virtual terminals and open VTs
# without a password prompt — required by the Minetest and terminal
# launch scripts, which run as the service user with no TTY.

stealth ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop speedometer
stealth ALL=(ALL) NOPASSWD: /usr/bin/systemctl start speedometer
stealth ALL=(ALL) NOPASSWD: /usr/bin/chvt
stealth ALL=(ALL) NOPASSWD: /usr/bin/openvt
